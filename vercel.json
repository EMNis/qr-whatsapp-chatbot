{
  "functions": {
    "src/**": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/src/index.html" },
    { "source": "/(.*)", "destination": "/src/$1" }
  ],
  "headers": [
    {
      "source": "/src/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}